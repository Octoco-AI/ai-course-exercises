# Copy this file to .env and fill in your key.
#   cp .env.example .env
#
# Get a free Gemini API key at: https://aistudio.google.com/apikey
# The free tier's rate limits are enough for this exercise, so your actual
# spend is likely $0 — the dollar numbers the scripts print come from token
# counts x list price, which is the comparison that matters.
GOOGLE_API_KEY=your_gemini_api_key_here

# Which repo the agent reads and edits. Defaults to the sibling
# expense-categoriser exercise so the fallback task in task.md runs out of the
# box. Point this at YOUR OWN repo to run the exercise on a real task — an
# absolute path is safest, e.g. WORKSPACE=/Users/you/code/your-project
WORKSPACE=../expense-categoriser

# Optional model overrides. The defaults match the M7 exercise. Any Gemini
# function-calling model works. Flash-lite is the ultra-budget executor option
# mentioned in the exercise (wider price gap).
# MONOLITHIC_MODEL=gemini-2.5-flash
# PLANNER_MODEL=gemini-2.5-pro
# EXECUTOR_MODEL=gemini-2.5-flash

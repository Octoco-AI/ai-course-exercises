# Copy to .env and fill in your key.
# Get a free key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: override the default model. Gemini 3.1 Flash-Lite is cheap and good for classification.
# GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: override the confidence threshold below which we fall back to the
# "Other" category instead of acting on a low-confidence prediction.
# CONFIDENCE_THRESHOLD=0.6

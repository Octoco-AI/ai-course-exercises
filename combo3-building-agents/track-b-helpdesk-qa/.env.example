# Copy to .env and fill in.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: model. Haiku 4.5 is usually enough for helpdesk scoping (classify,
# summarise, paraphrase KB content); Sonnet 5 when you want nicer prose.
# ANTHROPIC_MODEL=claude-haiku-4-5

# Workspace — seeded from ../chroma-corpora/track-b-helpdesk/docs/ via
# ./scripts/seed-workspace.sh. Defaults to ./workspace/.
# WORKSPACE_ROOT=./workspace

# Chroma index. Defaults to the sibling chroma-corpora directory.
# CHROMA_PERSIST_ROOT=../chroma-corpora/track-b-helpdesk/.chroma
# CHROMA_COLLECTION_NAME=track-b-helpdesk

# Output dirs for draft replies and human-escalation tickets.
# DRAFT_REPLIES_ROOT=./draft-replies
# ESCALATIONS_ROOT=./escalations

# Development port.
# PORT=8000

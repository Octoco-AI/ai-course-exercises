# Copy to .env and fill in.
# Get a key: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: which model to use. Sonnet 5 is the default — balanced for the
# codebase-Q&A agent. Use Haiku 4.5 for cheaper iteration during development,
# Opus 4.8 when you want the best quality (and can afford it).
# ANTHROPIC_MODEL=claude-sonnet-5

# Workspace the agent operates on. Defaults to ./workspace/. Must exist.
# WORKSPACE_ROOT=./workspace

# Where the agent's Chroma index lives. Defaults to
# ../chroma-corpora/track-a-codebase/.chroma (i.e. sibling to this directory).
# CHROMA_PERSIST_ROOT=../chroma-corpora/track-a-codebase/.chroma
# CHROMA_COLLECTION_NAME=track-a-codebase

# Output dir for draft_patch. Defaults to ./patches/.
# PATCHES_ROOT=./patches

# Development port for the FastAPI server.
# PORT=8000

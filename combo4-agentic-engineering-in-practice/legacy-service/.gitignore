# --- environment & secrets --------------------------------------------------
.env
.env.*
!.env.example

# --- virtualenvs ------------------------------------------------------------
.venv/
venv/
env/

# --- Python runtime ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --- build / packaging ------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# --- tooling caches ---------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- the sqlite database ----------------------------------------------------
# The DB is generated (seed_data.py / the app on boot); never commit it.
orderbase.db
*.db
*.sqlite3

# --- editors / OS -----------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store

# NOTE: logs/*.log ARE committed on purpose in this repo — they are fixtures
# for the debugging and microtooling modules. Do not add logs/ here.

# Copy to .env and adjust as needed. Nothing here is secret.

# Path to the sqlite database file. Read by src/legacy_service/db.py.
# Defaults to orderbase.db in the working directory if unset.
ORDERBASE_DB=orderbase.db

# Desired log level. NOTE: the current code hardcodes INFO in
# logging_setup.py; this var is here for the day we finally wire it up.
ORDERBASE_LOG_LEVEL=INFO
